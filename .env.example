# Quick local mode (works without Postgres)
DATABASE_URL=sqlite:///./llm_observability.db
APP_HOST=0.0.0.0
APP_PORT=8091
REQUEST_TIMEOUT_SECONDS=180

# Upstream provider proxy config
OPENAI_UPSTREAM_BASE_URL=https://api.openai.com
OPENAI_UPSTREAM_API_KEY=
ANTHROPIC_UPSTREAM_BASE_URL=https://api.anthropic.com
ANTHROPIC_UPSTREAM_API_KEY=

# Optional Postgres mode
POSTGRES_DB=llm_observability
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/llm_observability
